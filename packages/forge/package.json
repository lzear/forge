{
  "name": "@lzear/forge",
  "version": "4.1.2",
  "description": "Umbrella package for all lzear dev tooling",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lzear/forge.git",
    "directory": "packages/forge"
  },
  "author": "lzear",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./commitlint": {
      "types": "./dist/commitlint.d.ts",
      "default": "./dist/commitlint.js"
    },
    "./commitlint/emoji": {
      "types": "./dist/commitlint.emoji.d.ts",
      "default": "./dist/commitlint.emoji.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    },
    "./repo-lint": {
      "types": "./dist/repo-lint.d.ts",
      "default": "./dist/repo-lint.js"
    },
    "./tsconfig/app": "./tsconfig/app.json",
    "./tsconfig/lib": "./tsconfig/lib.json",
    "./tsconfig/react": "./tsconfig/react.json",
    "./tsup": {
      "types": "./dist/tsup.d.ts",
      "default": "./dist/tsup.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "default": "./dist/vitest.js"
    },
    "./vitest/react": {
      "types": "./dist/vitest.react.d.ts",
      "default": "./dist/vitest.react.js"
    }
  },
  "bin": "./dist/bin.js",
  "files": [
    "dist",
    "tsconfig"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1",
    "@lzear/configs": "workspace:*",
    "@lzear/eslint-config": "workspace:*",
    "@lzear/repo-lint": "workspace:*",
    "commander": "^15",
    "picocolors": "^1"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "tsup": "^8",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "tsup": "^8",
    "vite": "^8",
    "vitest": "^4"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "tsup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
