{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "description": "lzear dev tooling monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "lint": "eslint .",
    "ncu": "npx npm-check-updates --workspaces --upgrade --root && yarn && yarn up --recursive '*'",
    "prepare": "lefthook install",
    "qa": "yarn install --immutable && yarn build && concurrently -g 'yarn typecheck' 'yarn lint' 'yarn test' && yarn forge check",
    "setup-repo": "forge setup",
    "test": "yarn workspaces foreach -A run test",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0",
    "@changesets/cli": "^2",
    "@commitlint/cli": "^21",
    "@lzear/configs": "workspace:*",
    "@lzear/forge": "workspace:*",
    "concurrently": "^10",
    "eslint": "^9",
    "lefthook": "^2",
    "npm-check-updates": "^22",
    "typescript": "^6"
  },
  "resolutions": {
    "fflate": "0.8.2"
  },
  "type": "commonjs",
  "packageManager": "yarn@4.14.1"
}
